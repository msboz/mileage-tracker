rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Check if the signed-in user's email is in the adminEmails list
    function isAdmin() {
      let config = get(/databases/$(database)/documents/globalSettings/config);
      return request.auth != null
        && config.data.adminEmails != null
        && request.auth.token.email in config.data.adminEmails;
    }

    // Global settings: any authenticated user can read (needed for perMileRate)
    // Any authenticated user can write — password protection is enforced in the UI
    match /globalSettings/config {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can read user profiles (to get display names in Admin Dashboard)
      allow read: if isAdmin();
    }

    match /trips/{tripId} {
      // Users can read/write their own trips
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      // Admins can read, update (soft-delete/restore) and permanently delete all trips
      allow read, update, delete: if isAdmin();
    }

    // Admin audit log — only admins can read or write
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
